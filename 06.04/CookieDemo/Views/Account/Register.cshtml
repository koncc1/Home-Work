@model CookieDemo.Models.RegisterViewModel

<h2>Register</h2>

<form method="post">
    <div>
        <label>Login</label>
        <input asp-for="Login" />
    </div>
    <div>
        <label>Password</label>
        <input asp-for="Password" type="password" />
    </div>

    <button type="submit">Register</button>
</form>