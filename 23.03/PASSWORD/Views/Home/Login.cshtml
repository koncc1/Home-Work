@model PASSWORD.Models.LoginViewModel

<h2>Login</h2>

<form asp-action="Login" method="post">
    <p>Email:</p>
    <input asp-for="Email" />

    <p>Password:</p>
    <input asp-for="Password" type="password" />

    <br /><br />
    <button type="submit">Login</button>
</form>

<p>@ViewBag.Message</p>