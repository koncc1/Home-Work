@model HASHING.DTOs.LoginDto



<form method="post" asp-controller="Home" asp-action="Login">
    <div>
        <label>Email</label>
        <input type="text" name="Email" />
    </div>

    <div>
        <label>Password</label>
        <input type="password" name="Password" />
    </div>

    <button type="submit">Login</button>
</form>
